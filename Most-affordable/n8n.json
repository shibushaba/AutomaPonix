        "tableId": "requests",
        "columns": "message",
        "message": "={{ $('Extract Request Data').item.json.original_message }}"
      },
      "id": "insert-general-request",
      "name": "Supabase Insert Request",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
